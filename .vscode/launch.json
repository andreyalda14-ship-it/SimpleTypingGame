{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Start server",
      "program": "${workspaceFolder}/server.js",
      "cwd": "${workspaceFolder}",
      "presentation": {
        "group": "Server",
        "order": 1
      }
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Launch game in Chrome",
      "url": "http://localhost:8080",
      "webRoot": "${workspaceFolder}/public",
      "presentation": {
        "group": "Browsers",
        "order": 1
      }
    },
    {
      "type": "msedge",
      "request": "launch",
      "name": "Launch game in Edge",
      "url": "http://localhost:8080",
      "webRoot": "${workspaceFolder}/public",
      "presentation": {
        "group": "Browsers",
        "order": 2
      }
    },
    {
      "type": "firefox",
      "request": "launch",
      "name": "Launch game in Firefox",
      "url": "http://localhost:8080",
      "webRoot": "${workspaceFolder}/public",
      "reAttach": true,
      "presentation": {
        "group": "Browsers",
        "order": 3
      }
    },
    {
      "type": "safari",
      "request": "launch",
      "name": "Launch game in Safari",
      "url": "http://localhost:8080",
      "webRoot": "${workspaceFolder}/public",
      "presentation": {
        "group": "Browsers",
        "order": 4
      }
    }
  ],
  "compounds": [
    {
      "name": "Server + Chrome",
      "configurations": ["Start server", "Launch game in Chrome"],
      "stopAll": true,
      "presentation": {
        "group": "Server + Browser",
        "order": 1
      }
    },
    {
      "name": "Server + Edge",
      "configurations": ["Start server", "Launch game in Edge"],
      "stopAll": true,
      "presentation": {
        "group": "Server + Browser",
        "order": 2
      }
    },
    {
      "name": "Server + Firefox",
      "configurations": ["Start server", "Launch game in Firefox"],
      "stopAll": true,
      "presentation": {
        "group": "Server + Browser",
        "order": 3
      }
    },
    {
      "name": "Server + Safari",
      "configurations": ["Start server", "Launch game in Safari"],
      "stopAll": true,
      "presentation": {
        "group": "Server + Browser",
        "order": 4
      }
    }
  ]
}
