# --- Local development (SQLite, no DATABASE_URL needed) ---
# PORT=8080
# NODE_ENV=development
# TRUST_PROXY=0
# DATABASE_PATH=./scores.db

# --- Production (DigitalOcean App Platform) ---
# NODE_ENV=production
# DATABASE_URL=${your-db.DATABASE_URL}
# TRUST_PROXY=1
# Leave DATABASE_SSL unset (app uses TLS with rejectUnauthorized: false for managed DB)
# DATABASE_SSL=0  # only if you need to disable SSL entirely
