# --- Local development (SQLite, no DATABASE_URL needed) ---
#PORT=8080
#NODE_ENV=development
#TRUST_PROXY=0
# Optional: custom SQLite file path
# DATABASE_PATH=./scores.db

# --- Production (PostgreSQL on DigitalOcean, etc.) ---
 NODE_ENV=production
 DATABASE_URL=postgresql://user:password@host:25060/skytype?sslmode=require
 TRUST_PROXY=1
 DATABASE_SSL=0
