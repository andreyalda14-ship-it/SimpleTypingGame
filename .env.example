# Copy to .env for local development or production
PORT=8080
NODE_ENV=development

# PostgreSQL (required) — DigitalOcean Managed Database connection string
# Example: postgresql://user:password@host:25060/defaultdb?sslmode=require
DATABASE_URL=

# Set to 1 when behind a reverse proxy (nginx, App Platform load balancer, etc.)
TRUST_PROXY=0

# SSL: omit for sslmode in DATABASE_URL; set 0 for local Postgres without TLS
# DATABASE_SSL=0
